// Synerix Studio — Prisma schema
// Supabase Postgres. Runtime connects via Supavisor pooler (DATABASE_URL :6543,
// pgbouncer=true); migrations use the direct connection (DIRECT_URL :5432).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Tenancy ----------

// NextAuth v5 (Auth.js) user. Adapter-managed fields (email/name/image/
// emailVerified) + app relations. JWT session strategy — Session table kept
// only for adapter compatibility.
model User {
  id              String            @id @default(uuid())
  email           String            @unique
  name            String?
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime          @default(now())
  memberships     Membership[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  accounts        Account[]
  sessions        Session[]
  sentInvites     WorkspaceInvite[] @relation("InvitedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Email invite to a workspace. Accepted automatically when a user with a
// matching email signs in (see requireAuth bootstrap). Google OAuth proves the
// invitee controls the email, so no accept-token/code is needed; `expiresAt`
// just stops a PENDING invite from lingering open forever (null = no expiry,
// for legacy rows created before the column existed).
model WorkspaceInvite {
  id          String         @id @default(uuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        MembershipRole @default(EDITOR)
  invitedById String
  invitedBy   User           @relation("InvitedBy", fields: [invitedById], references: [id])
  status      InviteStatus   @default(PENDING)
  createdAt   DateTime       @default(now())
  expiresAt   DateTime?
  acceptedAt  DateTime?

  @@unique([workspaceId, email])
  @@index([email, status])
  @@map("workspace_invites")
}

// Customer account type — the three launch segments. Drives generation
// defaults (fidelity mode, prompt flavor) and which surfaces show.
enum WorkspaceType {
  FMCG_PRODUCT // product/SKU + festival/theme/custom-brief creatives
  APPAREL_ON_MODEL // everyday apparel worn by AI models
  FASHION_EDITORIAL // high-end apparel, editorial-campaign photoshoot look
}

model Workspace {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  ownerUserId     String
  owner           User              @relation("WorkspaceOwner", fields: [ownerUserId], references: [id])
  type            WorkspaceType     @default(FMCG_PRODUCT)
  // Onboarding profile — drives which surfaces show (e.g. Models / on-model
  // only for apparel-adjacent workspaces). All optional; onboarding may skip.
  industry        String?
  primaryUseCase  String?
  salesChannel    String?
  // Super-admin-only image-model override (a WORKSPACE_IMAGE_MODELS key). Null =
  // the default quality-first fallback cascade. Used to A/B cheaper models per
  // workspace (e.g. simple e-commerce apparel doesn't need the premium tier).
  imageModel      String?
  createdAt       DateTime          @default(now())
  memberships     Membership[]
  invites         WorkspaceInvite[]
  brands          Brand[]
  credits         WorkspaceCredits?
  ledger          CreditLedger[]
  calendarEntries CalendarEntry[]
  generationRuns  GenerationRun[]

  @@map("workspaces")
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model Membership {
  id          String         @id @default(uuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        MembershipRole @default(OWNER)
  createdAt   DateTime       @default(now())

  @@unique([workspaceId, userId])
  @@map("memberships")
}

// ---------- Brand ----------

enum IngestStatus {
  PENDING
  CRAWLING
  EXTRACTING
  READY
  FAILED
}

model Brand {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  websiteUrl  String?
  mottoText   String?

  // Full brand DNA blob (floki brandDnaSchema shape), plus promoted scalars
  // the compositor/pipeline read on every run.
  dna                Json?
  dnaConfidence      Json?
  primaryColorHex    String?
  secondaryColorsHex String[] @default([])
  accentColorsHex    String[] @default([])
  typographyStyle    String?
  photographyStyle   String?
  voiceRegister      String?
  oneLiner           String?

  logoAssetId            String?
  // Brand Block: logo placement defaults + fixed, brand-locked facts composited
  // on every creative. mottoText doubles as the tagline. contactLine is opt-in
  // per creative (off by default) — see ADR-0001 / CONTEXT.md.
  logoCorner             String?      @default("TL") // LogoPosition: TL|TR|TC|BL|BR
  logoScale              Float?       @default(1)
  contactLine            String? // e.g. "For business queries: 98xxxxxxxx"
  // Default output mode for this brand's apparel on-model creatives; the studio
  // can override it per run.
  apparelBrandingDefault BrandingMode @default(BRANDED)

  // Cached Creative Intelligence evidence pack (brand_os port): category ad
  // patterns, customer language, proven angles — researched once via web
  // search, consumed by every generation run's brief stage. Refresh manually.
  creativeIntel   Json?
  creativeIntelAt DateTime?

  ingestStatus IngestStatus @default(PENDING)
  ingestRunId  String?
  ingestError  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  assets          BrandAsset[]
  products        Product[]
  creatives       Creative[]
  calendarEntries CalendarEntry[]
  generationRuns  GenerationRun[]
  aiModels        AiModel[]

  @@index([workspaceId])
  @@map("brands")
}

enum BrandAssetKind {
  LOGO
  PRODUCT
  LIFESTYLE
  ICON
  OTHER
}

model BrandAsset {
  id             String         @id @default(uuid())
  brandId        String
  brand          Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  kind           BrandAssetKind @default(OTHER)
  storageKey     String
  mimeType       String
  width          Int?
  height         Int?
  sourceUrl      String?
  classification Json?
  isPrimaryLogo  Boolean        @default(false)
  createdAt      DateTime       @default(now())

  @@index([brandId])
  @@map("brand_assets")
}

// ---------- Products (SKUs) ----------

enum DissectionStatus {
  PENDING
  RUNNING
  READY
  FAILED
}

// Drives pipeline routing: APPAREL → On-model, FMCG → In-scene/Studio composite.
enum ProductCategory {
  FMCG
  APPAREL
  OTHER
}

model Product {
  id          String          @id @default(uuid())
  brandId     String
  brand       Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  description String?
  category    ProductCategory @default(OTHER)

  // labs-moodboard pattern: full vision analysis + <=400-char scene-replication
  // prefix, cached once per image set.
  dissectionPrompt        String?
  dissectionFull          Json?
  // Cached product-intelligence brief (category, preparation, finished form,
  // serving/occasions, DO/DON'T) — drives product-first concepting.
  productIntel            Json?
  dissectionStatus        DissectionStatus @default(PENDING)
  dissectionSourceImageId String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  images         ProductImage[]
  generationRuns GenerationRun[]

  @@index([brandId])
  @@map("products")
}

model ProductImage {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storageKey String
  // Background-removed packshot (white-flattened PNG), generated once at
  // upload by the product-cutout task and reused as the generation reference.
  cutoutKey  String?
  mimeType   String
  width      Int?
  height     Int?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// ---------- AI Models (on-model library) ----------

enum AiModelScope {
  GLOBAL // shared preset library, available to all brands (brandId null)
  BRAND // a brand's own saved/generated model
}

enum ModelGenStatus {
  PENDING
  RUNNING
  READY
  FAILED
}

// A reusable human-model reference image for On-model creatives. Presets are
// scope=GLOBAL (brandId null); brand-saved/generated models are scope=BRAND.
model AiModel {
  id          String         @id @default(uuid())
  scope       AiModelScope   @default(BRAND)
  brandId     String?
  brand       Brand?         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // Filterable attributes for the picker: {ageBand, gender, look, ...}
  traits      Json?
  storageKey  String?
  mimeType    String         @default("image/png")
  width       Int?
  height      Int?
  status      ModelGenStatus @default(READY)
  error       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  generationRuns GenerationRun[]

  @@index([brandId])
  @@index([scope])
  @@map("ai_models")
}

// ---------- Festivals & calendar ----------

enum FestivalCategory {
  RELIGIOUS
  NATIONAL
  COMMERCIAL
  SEASONAL
}

model Festival {
  id                  String               @id @default(uuid())
  slug                String               @unique
  name                String
  nameHindi           String?
  category            FestivalCategory
  regionTags          String[]             @default([])
  relevanceTags       String[]             @default([])
  // {imageryMotifs: string[], colorMotifs: string[], emotionalThemes: string[], greetingPhrases?: {...}}
  creativeContext     Json
  defaultLeadTimeDays Int                  @default(14) // v2 auto-draft placeholder
  occurrences         FestivalOccurrence[]

  @@map("festivals")
}

model FestivalOccurrence {
  id              String          @id @default(uuid())
  festivalId      String
  festival        Festival        @relation(fields: [festivalId], references: [id], onDelete: Cascade)
  year            Int
  date            DateTime        @db.Date
  endDate         DateTime?       @db.Date
  isApproximate   Boolean         @default(false)
  calendarEntries CalendarEntry[]

  @@unique([festivalId, year])
  @@index([date])
  @@map("festival_occurrences")
}

enum CalendarEntryKind {
  FESTIVAL
  CUSTOM
}

model CalendarEntry {
  id                   String              @id @default(uuid())
  workspaceId          String
  workspace            Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandId              String
  brand                Brand               @relation(fields: [brandId], references: [id], onDelete: Cascade)
  kind                 CalendarEntryKind
  festivalOccurrenceId String?
  festivalOccurrence   FestivalOccurrence? @relation(fields: [festivalOccurrenceId], references: [id])
  customTitle          String?
  customDate           DateTime?           @db.Date
  customContext        Json?
  // v2 auto-draft placeholders (decision: purely passive v1)
  optInForAutoDraft    Boolean             @default(false)
  leadTimeDays         Int?
  createdAt            DateTime            @default(now())
  generationRuns       GenerationRun[]

  @@index([workspaceId, brandId])
  @@map("calendar_entries")
}

// ---------- Generation ----------

enum GenerationTrigger {
  FESTIVAL
  CUSTOM
}

enum FidelityMode {
  IN_SCENE
  EXACT_PRODUCT
  ON_MODEL
}

// Apparel on-model output: BRANDED composites the logo + campaign text over the
// shot; PLAIN delivers just the model wearing the garment (no branding/text).
enum BrandingMode {
  BRANDED
  PLAIN
}

enum GenerationStatus {
  QUEUED
  BRIEFING
  CONCEPTING
  RENDERING
  QA
  COMPLETE
  PARTIAL
  FAILED
}

model GenerationRun {
  id              String         @id @default(uuid())
  workspaceId     String
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandId         String
  brand           Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  calendarEntryId String?
  calendarEntry   CalendarEntry? @relation(fields: [calendarEntryId], references: [id])
  productId       String?
  product         Product?       @relation(fields: [productId], references: [id])

  trigger          GenerationTrigger
  customBrief      String?
  // Direct mode: customBrief is a LITERAL scene prompt; skip concepting, 1 render.
  directMode       Boolean           @default(false)
  // Super-admin model bake-off: every concept renders once per model in the
  // fixed lineup (no fallback), side-by-side, no credit debit; costs logged.
  bakeoff          Boolean           @default(false)
  // User's image-model pick: "nb-pro" | "gpt-image-2" | "compare" (renders both,
  // costs double credits). Null = legacy runs before the picker (default chain).
  imageModelPref   String?
  fidelityMode     FidelityMode      @default(IN_SCENE) // IN_SCENE = AI places real product; EXACT_PRODUCT = studio composite; ON_MODEL = apparel on AI model
  // On-model runs: the AI Model whose reference photo is fused with the garment.
  aiModelId        String?
  aiModel          AiModel?          @relation(fields: [aiModelId], references: [id])
  // Apparel on-model: BRANDED overlays logo + text; PLAIN ships the clean shot.
  brandingMode     BrandingMode      @default(BRANDED)
  // Optional pose direction for on-model apparel (empty = AI varies it per concept).
  modelPose        String?
  // On-model multi-pose: same model + garment rendered once per pose in a single
  // run (poses are the variation axis, replacing the concept count). Empty = the
  // legacy single-concept behavior driven by modelPose/conceptCount.
  modelPoses       String[]          @default([])
  requestedAspects String[]          @default(["4:5"])
  language         String            @default("en") // creative copy default; all langs generated
  conceptCount     Int               @default(4) // how many distinct creative options to generate (guided runs)

  status   GenerationStatus @default(QUEUED)
  // Stage accumulator (single source of truth across Trigger.dev retries):
  // {occasionBrief, concepts: CreativeConcept[], iterations: Record<conceptId, RenderIteration[]>}
  pipeline Json             @default("{}")

  creditsDebited Decimal   @default(0) @db.Decimal(12, 2)
  triggerRunId   String?
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  creatives Creative[]

  @@index([workspaceId, status])
  @@map("generation_runs")
}

enum CreativeStatus {
  DRAFTING
  READY
  FAILED
  ARCHIVED
}

model Creative {
  id              String        @id @default(uuid())
  generationRunId String
  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  brandId         String
  brand           Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  conceptIndex    Int

  concept            Json // typed CreativeConcept
  masterPlateKey     String?
  masterAspect       String?
  // Actual image model that rendered the master plate (cost-model id, e.g.
  // "gemini-3.1-flash-image"); provenance for bake-off comparison and audits.
  imageModel         String?
  status             CreativeStatus @default(DRAFTING)
  qa                 Json? // floki QA shape: {status: production_ready|review|failed, rules, judge}
  critic             Json? // final RenderIteration axes + score
  usedCutoutFallback Boolean        @default(false)
  // Human-review gate: a creative is not client-ready (exportable/shareable)
  // until an operator approves it in the studio. Automated QA (brief
  // validation, pack/on-model fidelity, overlay placement) raises the floor
  // upstream; this flag is the human final call.
  approved           Boolean        @default(false)
  approvedAt         DateTime?
  // Soft delete — hidden from every listing/read, never physically removed
  // (renders and versions stay recoverable).
  deletedAt          DateTime?

  currentVersionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  renders  CreativeRender[]
  versions CreativeVersion[]

  @@index([brandId, status])
  @@map("creatives")
}

enum RenderStatus {
  PENDING
  COMPOSED
  FAILED
}

model CreativeRender {
  id               String       @id @default(uuid())
  creativeId       String
  creative         Creative     @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  aspectRatio      String
  // Deterministic compositor input: archetype, canvas dims, resolved colors,
  // text layers {role, textByLang, font, sizePx, x/y/w/h, align, color}, logo layer.
  overlaySpec      Json
  composedImageKey String?
  status           RenderStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([creativeId, aspectRatio])
  @@map("creative_renders")
}

model CreativeVersion {
  id               String   @id @default(uuid())
  creativeId       String
  creative         Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  index            Int
  // {type: 'initial'|'text_edit'|'aspect_render'|'regen_instruction'|'revert', note?, fromVersionIndex?}
  cause            Json
  overlaySpec      Json
  masterPlateKey   String?
  composedImageKey String
  aspectRatio      String
  createdAt        DateTime @default(now())

  @@unique([creativeId, index])
  @@map("creative_versions")
}

// ---------- Credits ----------

enum CreditReason {
  MANUAL_GRANT
  SIGNUP_GRANT
  GENERATION
  REGEN_INSTRUCTION
  ENHANCE_PROMPT
  REFUND
}

model WorkspaceCredits {
  workspaceId String    @id
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  balance     Decimal   @default(0) @db.Decimal(12, 2)
  updatedAt   DateTime  @updatedAt

  @@map("workspace_credits")
}

model CreditLedger {
  id              String       @id @default(uuid())
  workspaceId     String
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  delta           Decimal      @db.Decimal(12, 2) // +grant / -debit
  reason          CreditReason
  generationRunId String?
  balanceAfter    Decimal      @db.Decimal(12, 2)
  note            String?
  createdAt       DateTime     @default(now())

  @@index([workspaceId, createdAt])
  @@map("credit_ledger")
}

// ---------- Cost observability ----------

// One row per billable API call (LLM or image) across the pipeline. Populated
// from CostTracker output. `usd` is a token-accurate estimate at list prices
// (images are per-call list price), NOT the provider invoice. Grouped by
// run / workspace / source / model for spend observation. No FK on workspaceId
// so log history survives workspace deletion.
model ApiCostLog {
  id           String      @id @default(uuid())
  workspaceId  String?
  runId        String? // GenerationRun id when the call belongs to a run
  source       String // "generation" | "dissect" | "brand-research" | "enhance" | "editor"
  kind         ApiCostKind
  provider     String // "anthropic" | "google" | "openai" | "runware" | "other"
  model        String
  stage        String // pipeline stage label
  inputTokens  Int         @default(0)
  outputTokens Int         @default(0)
  imageCount   Int         @default(0)
  usd          Decimal     @db.Decimal(12, 6)
  createdAt    DateTime    @default(now())

  @@index([workspaceId, createdAt])
  @@index([runId])
  @@index([createdAt])
  @@map("api_cost_log")
}

enum ApiCostKind {
  LLM
  IMAGE
}

// ---------- Synerix website (consulting) ----------
// Ported from the pre-merge Pinata site. Table names
// (@@map) and cuid IDs are preserved so legacy rows copy across 1:1 via
// scripts/migrate-legacy-pinata.ts.

model Test {
  id          String   @id @default(cuid())
  name        String
  type        String // 'paid' or 'free'
  description String?
  questions   Json // Array of questions with options and weightage
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testResults TestResult[] @relation("TestResults")

  @@map("tests")
}

model TestResult {
  id                  String   @id @default(cuid())
  testId              String
  phoneNumber         String
  email               String
  name                String
  businessName        String
  businessDescription String
  testScore           Int
  answers             Json // Array of {questionId, optionId, weightAge}
  categoryAnalysis    Json
  recommendations     Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  test Test @relation("TestResults", fields: [testId], references: [id], onDelete: Cascade)

  @@index([email, phoneNumber])
  @@index([testId, createdAt])
  @@map("test_results")
}
