# Copy to .env.local (Next.js) AND mirror to .env (the Trigger.dev worker
# reads .env). Values here are placeholders — never commit real secrets.

# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"   # Supavisor pooler (runtime)
DIRECT_URL="postgresql://user:pass@host:5432/postgres"                    # direct (migrations)

# --- Auth (NextAuth v5, Google-only) ---
AUTH_SECRET=""                       # npx auth secret
AUTH_URL="http://localhost:6969"     # prod: https://www.synerix.in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SUPER_ADMIN_EMAIL="consulting.synerix@gmail.com"
DEV_AUTH_BYPASS="1"                  # dev only; inert in production builds

# --- Storage (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Trigger.dev v4 ---
TRIGGER_PROJECT_REF=""
TRIGGER_SECRET_KEY=""                # tr_dev_… locally, tr_prod_… on Vercel

# --- AI providers ---
ANTHROPIC_API_KEY=""                 # concepts, briefs, QA judges
GOOGLE_GENERATIVE_AI_API_KEY=""      # Gemini image models + marketing chat bot
OPENAI_API_KEY=""                    # gpt-image fallback
RUNWARE_API_KEY=""                   # seedream fallback
FIRECRAWL_API_KEY=""                 # brand-site ingest crawl
FAL_KEY=""                           # optional provider

# --- Email (Gmail SMTP: invites, enquiry, health-check reports) ---
GMAIL_USERNAME=""
GMAIL_PASSWORD=""                    # Gmail app password

# --- Marketing site ---
WEBSITE_URL="https://www.synerix.in"
WHATSAPP_NUMBER=""

# Optional tunables (all have sane defaults in code): PACK_QA_MAX_RETRIES,
# COMPOSE_VARIANTS, MAX_CONCEPTS_PER_RUN, MAX_CONCURRENT_CONCEPTS,
# IMAGE_PROVIDER, GEMINI_IMAGE_MODEL*, MODEL_* (per-stage LLM ids), PRICE_*,
# CREDITS_*, SIGNUP_CREDIT_GRANT, BRAND_INTEL_STALE_MS, SENTRY_DSN.
